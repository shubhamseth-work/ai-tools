{
  "name": "google-cloud-api",
  "version": "1.0.0",
  "description": "Cloud Run and Google APIs",
  "main": "server.js",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "mocha \"**/*.test.js\"",
    "test:watch": "mocha --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "mcp": "npx @smithery/cli run firestore-mcp"
  },
  "dependencies": {
    "@google-cloud/documentai": "^9.3.0",
    "@google-cloud/pubsub": "^5.2.0",
    "@google-cloud/storage": "^7.16.0",
    "@google/genai": "^1.11.0",
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.10.0",
    "cors": "^2.8.5",
    "csv-writer": "^1.6.0",
    "dotenv": "^17.2.1",
    "express": "^4.21.2",
    "fast-csv": "^5.0.5",
    "firebase-admin": "^12.0.0",
    "langchain": "^0.3.30",
    "newrelic": "^13.0.0",
    "openai": "^5.16.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "sanitize-html": "^2.17.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "chai": "^5.2.1",
    "eslint": "^9.0.0",
    "mocha": "^11.7.1",
    "nodemon": "^3.1.10",
    "prettier": "^3.0.0",
    "sinon": "^21.0.0",
    "supertest": "^7.1.3"
  },
  "keywords": [
    "GCP",
    "Cloud Run",
    "Node.js"
  ],
  "author": "shubham_seth",
